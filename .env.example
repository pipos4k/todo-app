# Database Configuration
DB_ENGINE=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_password

# Constructed DATABASE_URL
DATABASE_URL=${DB_ENGINE}://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-random-string

# JWT Configuration
JWT_SECRET_KEY = change-this-to-random-string
JWT_ACCESS_TOKEN_EXPIRES = 3600

# FOR SECRET KEYS YOU CAN USE (ON TERMINAL): python -c 'import secrets; print(secrets.token_hex(32))'